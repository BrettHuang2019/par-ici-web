          "start": 11.28,
          "end": 14.16
        },
        {
          "text": "sont toujours privés d'électricité,",
          "translations": {
            "zh": "仍然断电，",
            "en": "are still without electricity,",
            "es": "siguen sin electricidad,"
          },
          "start": 14.16,
          "end": 15.84
